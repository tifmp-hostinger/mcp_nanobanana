# === Cowork Image MCP — variaveis de ambiente (defina no EasyPanel) ===
# NAO faca commit do .env real.

# Chave do Google AI Studio (obrigatoria). Billing ATIVO (geracao de imagem e paga).
GEMINI_API_KEY=cole_sua_chave_aqui

# URL publica do servico (obrigatoria p/ OAuth). Vira o "issuer".
PUBLIC_BASE_URL=https://SEU-DOMINIO.easypanel.host

# Senha que autoriza o acesso na tela de login do OAuth (obrigatoria). Use algo forte.
AUTH_PASSWORD=troque_por_uma_senha_forte

# Pasta persistente da chave de assinatura e clientes (use um VOLUME no EasyPanel).
OAUTH_DATA_DIR=/app/oauth-data

# Opcionais:
# GEMINI_MODEL=gemini-2.5-flash-image
# PORT=8080
# TOKEN_TTL_SEC=3600
# IMAGES_OUT_DIR=/app/imagens-geradas
